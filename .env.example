# ===========================================================================
# DCC Synthetic Liquidity Engine — Environment Variables
# ===========================================================================
# Copy this file to .env.local for local development.
# NEVER commit real secrets to version control.
# ===========================================================================

# ── General ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://dcc:dcc_dev_password@localhost:5432/dcc_liquidity
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── DCC Node ───────────────────────────────────────────────────────────────
DCC_NODE_URL=http://localhost:4000
DCC_CHAIN_ID=dcc-devnet

# ── Service Ports ──────────────────────────────────────────────────────────
# market-data-service
MARKET_DATA_PORT=3001
# quote-engine
QUOTE_ENGINE_PORT=3002
# router-service
ROUTER_PORT=3003
# execution-service
EXECUTION_PORT=3004
# relayer-service
RELAYER_PORT=3005
# redemption-service
REDEMPTION_PORT=3006
# risk-monitor-service
RISK_MONITOR_PORT=3007
# inventory-rebalancer
INVENTORY_REBALANCER_PORT=3008

# ── Jupiter (Solana) ──────────────────────────────────────────────────────
JUPITER_API_URL=https://quote-api.jup.ag/v6
JUPITER_TIMEOUT_MS=5000
JUPITER_MAX_STALENESS_MS=10000

# ── Raydium (Solana) ─────────────────────────────────────────────────────
RAYDIUM_API_URL=https://api-v3.raydium.io
RAYDIUM_TIMEOUT_MS=5000
RAYDIUM_MAX_STALENESS_MS=10000

# ── Uniswap (Ethereum) ──────────────────────────────────────────────────
UNISWAP_API_URL=https://api.uniswap.org/v2
UNISWAP_TIMEOUT_MS=8000
UNISWAP_MAX_STALENESS_MS=15000
# UNISWAP_API_KEY=         # optional, for higher rate limits

# ── Relayer Wallets ──────────────────────────────────────────────────────
# WARNING: These are HOT KEYS. Restrict permissions and use hardware signers
# in production.
# RELAYER_DCC_PRIVATE_KEY=
# RELAYER_SOLANA_PRIVATE_KEY=
# RELAYER_EVM_PRIVATE_KEY=

# ── Risk Defaults ────────────────────────────────────────────────────────
DEFAULT_ESCROW_TIMEOUT_MS=300000
MAX_ESCROW_TIMEOUT_MS=900000
GLOBAL_STALE_QUOTE_THRESHOLD_MS=30000

# ── Observability ────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=dcc-liquidity
